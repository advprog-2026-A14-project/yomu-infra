{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "JVM Heap & Threads profiling for Spring Boot (Java), plus database and connection pool monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "JVM → Heap Memory Used vs Committed vs Max",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Bytes",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": {"tooltip": false, "legend": false, "viz": false},
            "lineWidth": 2
          },
          "unit": "bytes"
        }
      },
      "targets": [
        {"expr": "jvm_memory_used_bytes{job=~\"java|java-staging\", area=\"heap\"}", "legendFormat": "{{job}} - used (heap)", "refId": "A"},
        {"expr": "jvm_memory_committed_bytes{job=~\"java|java-staging\", area=\"heap\"}", "legendFormat": "{{job}} - committed (heap)", "refId": "B"},
        {"expr": "jvm_memory_max_bytes{job=~\"java|java-staging\", area=\"heap\"}", "legendFormat": "{{job}} - max (heap)", "refId": "C"}
      ]
    },
    {
      "id": 2,
      "title": "JVM → Non-Heap Memory Used",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "bytes"
        }
      },
      "targets": [
        {"expr": "jvm_memory_used_bytes{job=~\"java|java-staging\", area=\"nonheap\"}", "legendFormat": "{{job}} - used (nonheap)", "refId": "A"}
      ]
    },
    {
      "id": 3,
      "title": "JVM → Live Threads vs Daemon Threads",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {"expr": "jvm_threads_live_threads{job=~\"java|java-staging\"}", "legendFormat": "{{job}} - live", "refId": "A"},
        {"expr": "jvm_threads_daemon_threads{job=~\"java|java-staging\"}", "legendFormat": "{{job}} - daemon", "refId": "B"}
      ]
    },
    {
      "id": 4,
      "title": "JVM → GC Pause Time (max over interval)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "s"
        }
      },
      "targets": [
        {"expr": "jvm_gc_pause_seconds_max{job=~\"java|java-staging\"}", "legendFormat": "{{job}} - {{action}}", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "JVM → CPU Usage",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "percentunit"
        }
      },
      "targets": [
        {"expr": "process_cpu_usage{job=~\"java|java-staging\"}", "legendFormat": "{{job}}", "refId": "A"}
      ]
    },
    {
      "id": 6,
      "title": "JVM → Loaded Classes",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {"expr": "jvm_classes_loaded_classes{job=~\"java|java-staging\"}", "legendFormat": "{{job}} - loaded", "refId": "A"},
        {"expr": "jvm_classes_unloaded_classes_total{job=~\"java|java-staging\"}", "legendFormat": "{{job}} - unloaded", "refId": "B"}
      ]
    },
    {
      "id": 7,
      "title": "DB → Connection Pool Active / Total",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {"expr": "hikaricp_connections_active{job=~\"java|java-staging\"}", "legendFormat": "{{job}} active", "refId": "A"},
        {"expr": "hikaricp_connections_total{job=~\"java|java-staging\"}", "legendFormat": "{{job}} total", "refId": "B"}
      ]
    },
    {
      "id": 8,
      "title": "DB → Active Connections (pg_stat_activity)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {"expr": "pg_stat_activity_count{datname=~\"yomu_.*\"}", "legendFormat": "{{datname}} active", "refId": "A"}
      ]
    },
    {
      "id": 9,
      "title": "DB → Transactions Committed / Rolled Back",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {"expr": "rate(pg_stat_database_xact_commit{datname=~\"yomu_.*\"}[1m])", "legendFormat": "{{datname}} commits/s", "refId": "A"},
        {"expr": "rate(pg_stat_database_xact_rollback{datname=~\"yomu_.*\"}[1m])", "legendFormat": "{{datname}} rollbacks/s", "refId": "B"}
      ]
    },
    {
      "id": 10,
      "title": "DB → Block Cache Hit Ratio",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "percent"
        }
      },
      "targets": [
        {"expr": "(rate(pg_stat_database_blks_hit{datname=~\"yomu_.*\"}[1m]) / (rate(pg_stat_database_blks_hit{datname=~\"yomu_.*\"}[1m]) + rate(pg_stat_database_blks_read{datname=~\"yomu_.*\"}[1m]))) * 100 or on() vector(0)", "legendFormat": "{{datname}} cache hit %", "refId": "A"}
      ]
    },
    {
      "id": 11,
      "title": "Redis → Memory Used (bytes)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "bytes"
        }
      },
      "targets": [
        {"expr": "redis_memory_used_bytes{addr=~\"redis.*\"}", "legendFormat": "{{addr}} used", "refId": "A"},
        {"expr": "redis_memory_used_rss_bytes{addr=~\"redis.*\"}", "legendFormat": "{{addr}} rss", "refId": "B"}
      ]
    },
    {
      "id": 12,
      "title": "Redis → Connected Clients",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2},
          "unit": "short"
        }
      },
      "targets": [
        {"expr": "redis_connected_clients{addr=~\"redis.*\"}", "legendFormat": "{{addr}} clients", "refId": "A"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
