 \u2192 HTTP Latency P50 / P99", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2}, "unit": "s"}}, "targets": [{"expr": "histogram_quantile(0.50, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=~\"java|java-staging\"}[1m]))) > 0", "legendFormat": "p50 {{uri}}", "refId": "A"}, {"expr": "histogram_quantile(0.99, sum by (le, uri) (rate(http_server_requests_seconds_bucket{job=~\"java|java-staging\"}[1m]))) > 0", "legendFormat": "p99 {{uri}}", "refId": "B"}]}, {"id": 16, "title": "JVM \u2192 HTTP Status Code Distribution", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 56}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2}, "unit": "reqps"}}, "targets": [{"expr": "sum by (status) (rate(http_server_requests_seconds_count{job=~\"java|java-staging\"}[1m]))", "legendFormat": "HTTP {{status}}", "refId": "A"}]}, {"id": 17, "title": "JVM \u2192 HTTP Error Rate (4xx + 5xx %)", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 56}, "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"fillOpacity": 20, "gradientMode": "opacity", "lineWidth": 2}, "unit": "percent"}}, "targets": [{"expr": "(sum(rate(http_server_requests_seconds_count{job=~\"java|java-staging\",status=~\"4..|5..\"}[1m])) or on() vector(0)) / (sum(rate(http_server_requests_seconds_count{job=~\"java|java-staging\"}[1m])) or on() vector(0)) * 100", "legendFormat": "{{job}} error %", "refId": "A"}]}, {"id": 18, "title": "JVM \u2192 Active HTTP Requests (in-flight)", "type": "timeseries", "datasource": {"type": "p