# ============================================================
# Yomu Platform - Docker Compose Environment Configuration
# ============================================================
# Copy this file to .env and update values before deploying.
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ============================================================

# --- Image Tag ---
# Production blue/green image tag
IMAGE_TAG=latest
# Staging image tag (can differ from production)
STAGING_IMAGE_TAG=staging

# --- PostgreSQL ---
# Databases are auto-created on first startup:
#   yomu_db       (production Java)
#   yomu_engine   (production Rust)
#   yomu_db_staging       (staging Java)
#   yomu_engine_staging   (staging Rust)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=yomu_db

# --- Redis (optional password) ---
REDIS_PASSWORD=

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-admin-password

# --- Application Secrets ---
JWT_SECRET=change-me-jwt-secret
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
INTERNAL_API_KEY=change-me-internal-key
JAVA_CORE_API_KEY=change-me-internal-key

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317