# ============================================================
# Yomu Platform - Environment Configuration Template
# ============================================================
# Copy this file to .env and replace all placeholder values with
# strong, unique secrets before deploying.
#
# ⚠️  NEVER commit the .env file to version control.
# ============================================================

# --- Docker Image Tags -------------------------------------------------------
# Tag used for production blue/green deployments
IMAGE_TAG=latest

# Tag used for the staging environment
STAGING_IMAGE_TAG=staging

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=yomu_db

# Auto-created databases on first startup:
#   yomu_db              (production Java backend)
#   yomu_engine          (production Rust backend)
#   yomu_db_staging      (staging Java backend)
#   yomu_engine_staging  (staging Rust backend)

# --- Redis -------------------------------------------------------------------
# Optional: leave empty if Redis runs without AUTH
REDIS_PASSWORD=

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-admin-password

# --- Application Secrets -----------------------------------------------------
# Signing key for JWT tokens (min 32 chars, keep it secret)
JWT_SECRET=change-me-jwt-secret-min-32-chars

# Internal service-to-service API key (shared between Java and Rust)
INTERNAL_API_KEY=change-me-internal-api-key

# Key Rust uses to authenticate with the Java core backend
JAVA_CORE_API_KEY=change-me-java-core-api-key

# Google OAuth 2.0 Client ID (optional, leave empty to disable)
GOOGLE_OAUTH_CLIENT_ID=

# --- OpenTelemetry -----------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
